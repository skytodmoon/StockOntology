<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:stock="http://stock-ontology.org/">

    <owl:Ontology rdf:about="http://stock-ontology.org/investor">
        <rdfs:comment>投资者本体模块</rdfs:comment>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>

    <!-- 投资者类 -->
    <owl:Class rdf:about="http://stock-ontology.org/Investor">
        <rdfs:label>投资者</rdfs:label>
        <rdfs:comment>参与股票市场投资的实体</rdfs:comment>
    </owl:Class>

    <!-- 投资者子类 -->
    <owl:Class rdf:about="http://stock-ontology.org/InstitutionalInvestor">
        <rdfs:label>机构投资者</rdfs:label>
        <rdfs:comment>以机构形式参与投资的实体</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/Investor"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/Fund">
        <rdfs:label>基金</rdfs:label>
        <rdfs:comment>公募或私募基金</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/InstitutionalInvestor"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/MutualFund">
        <rdfs:label>公募基金</rdfs:label>
        <rdfs:comment>向公众发行的基金</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/Fund"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/PrivateFund">
        <rdfs:label>私募基金</rdfs:label>
        <rdfs:comment>向特定投资者发行的基金</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/Fund"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/QFII">
        <rdfs:label>合格境外机构投资者</rdfs:label>
        <rdfs:comment>Qualified Foreign Institutional Investor</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/InstitutionalInvestor"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/SocialSecurity">
        <rdfs:label>社保基金</rdfs:label>
        <rdfs:comment>社会保障基金</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/InstitutionalInvestor"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/Insurance">
        <rdfs:label>保险公司</rdfs:label>
        <rdfs:comment>保险资金</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/InstitutionalInvestor"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/Broker">
        <rdfs:label>券商</rdfs:label>
        <rdfs:comment>证券公司</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/InstitutionalInvestor"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/Trust">
        <rdfs:label>信托</rdfs:label>
        <rdfs:comment>信托公司</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/InstitutionalInvestor"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/RetailInvestor">
        <rdfs:label>散户投资者</rdfs:label>
        <rdfs:comment>个人投资者</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/Investor"/>
    </owl:Class>

    <!-- 投资者数据属性 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasInvestorId">
        <rdfs:label>投资者ID</rdfs:label>
        <rdfs:comment>投资者的唯一标识符</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Investor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasInvestorName">
        <rdfs:label>投资者名称</rdfs:label>
        <rdfs:comment>投资者的名称</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Investor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasInvestorType">
        <rdfs:label>投资者类型</rdfs:label>
        <rdfs:comment>投资者的分类类型</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Investor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasTotalAssets">
        <rdfs:label>管理资产</rdfs:label>
        <rdfs:comment>投资者管理的总资产规模</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Investor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <!-- 持仓关系属性 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasShares">
        <rdfs:label>持股数量</rdfs:label>
        <rdfs:comment>持有股票的数量</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasHoldingRatio">
        <rdfs:label>持股比例</rdfs:label>
        <rdfs:comment>持有股票占总股本的比例</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasMarketValue">
        <rdfs:label>持仓市值</rdfs:label>
        <rdfs:comment>持有股票的市值</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasHoldingDate">
        <rdfs:label>持仓日期</rdfs:label>
        <rdfs:comment>持仓报告的日期</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <!-- 投资者对象属性 -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/holds">
        <rdfs:label>持有</rdfs:label>
        <rdfs:comment>投资者持有公司股票</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Investor"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/Company"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://stock-ontology.org/holdedBy">
        <rdfs:label>被持有</rdfs:label>
        <rdfs:comment>公司股票被投资者持有</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Company"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/Investor"/>
        <owl:inverseOf rdf:resource="http://stock-ontology.org/holds"/>
    </owl:ObjectProperty>

</rdf:RDF>
