<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:stock="http://stock-ontology.org/">

    <owl:Ontology rdf:about="http://stock-ontology.org/">
        <rdfs:comment>股票市场本体 - Stock Market Ontology v2.0</rdfs:comment>
        <rdfs:comment>本体驱动的股票分析预测系统核心语义底座</rdfs:comment>
        <owl:versionInfo>2.0.0</owl:versionInfo>
    </owl:Ontology>

    <!-- ==================== Classes ==================== -->

    <!-- 基础类 -->
    <owl:Class rdf:about="http://stock-ontology.org/FinancialEntity">
        <rdfs:label>金融实体</rdfs:label>
        <rdfs:comment>所有金融实体的基类</rdfs:comment>
    </owl:Class>

    <!-- 公司类 -->
    <owl:Class rdf:about="http://stock-ontology.org/Company">
        <rdfs:label>公司</rdfs:label>
        <rdfs:comment>上市公司实体</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/FinancialEntity"/>
        <!-- 公理约束：Company 必须属于至少一个 Industry -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://stock-ontology.org/belongsToIndustry"/>
                <owl:someValuesFrom rdf:resource="http://stock-ontology.org/Industry"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- 行业类 -->
    <owl:Class rdf:about="http://stock-ontology.org/Industry">
        <rdfs:label>行业</rdfs:label>
        <rdfs:comment>行业分类</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/FinancialEntity"/>
    </owl:Class>

    <!-- 财务报告类 -->
    <owl:Class rdf:about="http://stock-ontology.org/FinancialReport">
        <rdfs:label>财务报告</rdfs:label>
        <rdfs:comment>公司财务报告</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/FinancialEntity"/>
        <!-- 公理约束：FinancialReport 必须有报告日期 -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://stock-ontology.org/hasReportDate"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- 市场事件类 -->
    <owl:Class rdf:about="http://stock-ontology.org/MarketEvent">
        <rdfs:label>市场事件</rdfs:label>
        <rdfs:comment>市场相关事件</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/FinancialEntity"/>
        <!-- 公理约束：MarketEvent 必须有事件日期和影响级别 -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://stock-ontology.org/hasEventDate"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- 投资者类 -->
    <owl:Class rdf:about="http://stock-ontology.org/Investor">
        <rdfs:label>投资者</rdfs:label>
        <rdfs:comment>投资者实体</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/FinancialEntity"/>
    </owl:Class>

    <!-- 事件子类 -->
    <owl:Class rdf:about="http://stock-ontology.org/PolicyEvent">
        <rdfs:label>政策事件</rdfs:label>
        <rdfs:comment>政策相关事件（央行、国务院、监管机构发布的政策）</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/MarketEvent"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/CompanyEvent">
        <rdfs:label>公司事件</rdfs:label>
        <rdfs:comment>公司相关事件（财报发布、并购重组、高管变动等）</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/MarketEvent"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/MacroEvent">
        <rdfs:label>宏观事件</rdfs:label>
        <rdfs:comment>宏观经济事件（GDP、CPI、PMI、汇率变动等）</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/MarketEvent"/>
    </owl:Class>

    <!-- 投资者子类 -->
    <owl:Class rdf:about="http://stock-ontology.org/InstitutionalInvestor">
        <rdfs:label>机构投资者</rdfs:label>
        <rdfs:comment>机构投资者（基金、券商、保险等）</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/Investor"/>
    </owl:Class>

    <owl:Class rdf:about="http://stock-ontology.org/RetailInvestor">
        <rdfs:label>散户投资者</rdfs:label>
        <rdfs:comment>个人投资者</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/Investor"/>
    </owl:Class>

    <!-- ==================== 新增类：分析推理相关 ==================== -->

    <!-- 分析结果类 -->
    <owl:Class rdf:about="http://stock-ontology.org/AnalysisResult">
        <rdfs:label>分析结果</rdfs:label>
        <rdfs:comment>分析结果实体，所有分析结论的统一表示，支持溯源</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://stock-ontology.org/FinancialEntity"/>
        <!-- 公理约束：AnalysisResult 必须有置信度 -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://stock-ontology.org/hasConfidence"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <!-- 公理约束：AnalysisResult 必须有溯源ID -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://stock-ontology.org/hasTraceId"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- 因果传导链类 -->
    <owl:Class rdf:about="http://stock-ontology.org/CausalChain">
        <rdfs:label>因果传导链</rdfs:label>
        <rdfs:comment>记录完整的推理路径，从源事件到最终影响的传导链</rdfs:comment>
        <!-- 公理约束：CausalChain 必须有置信度 -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://stock-ontology.org/hasConfidence"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- 推理步骤类 -->
    <owl:Class rdf:about="http://stock-ontology.org/ReasoningStep">
        <rdfs:label>推理步骤</rdfs:label>
        <rdfs:comment>因果链中的单步推理记录，包含规则名称、源节点、目标节点、证据</rdfs:comment>
    </owl:Class>

    <!-- 预测记录类 -->
    <owl:Class rdf:about="http://stock-ontology.org/PredictionRecord">
        <rdfs:label>预测记录</rdfs:label>
        <rdfs:comment>模型预测的留痕实体，记录模型版本、输入特征、输出结果</rdfs:comment>
        <!-- 公理约束：PredictionRecord 必须有置信度 -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://stock-ontology.org/hasConfidence"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- 技术指标类 -->
    <owl:Class rdf:about="http://stock-ontology.org/TechnicalIndicator">
        <rdfs:label>技术指标</rdfs:label>
        <rdfs:comment>技术指标实体（MA/RSI/MACD/Bollinger等）</rdfs:comment>
    </owl:Class>

    <!-- 情感记录类 -->
    <owl:Class rdf:about="http://stock-ontology.org/SentimentRecord">
        <rdfs:label>情感记录</rdfs:label>
        <rdfs:comment>情感分析记录，关联新闻来源和分析结果</rdfs:comment>
    </owl:Class>

    <!-- ==================== Data Properties ==================== -->

    <!-- 公司属性 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasStockCode">
        <rdfs:label>股票代码</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasStockName">
        <rdfs:label>股票名称</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasMarketCap">
        <rdfs:label>市值</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasListDate">
        <rdfs:label>上市日期</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Company"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <!-- 行业属性 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasIndustryCode">
        <rdfs:label>行业代码</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Industry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasIndustryName">
        <rdfs:label>行业名称</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Industry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasIndustryLevel">
        <rdfs:label>行业级别</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Industry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <!-- 财务报告属性 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasReportDate">
        <rdfs:label>报告日期</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/FinancialReport"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasRevenue">
        <rdfs:label>营业收入</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/FinancialReport"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasNetProfit">
        <rdfs:label>净利润</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/FinancialReport"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasROE">
        <rdfs:label>净资产收益率</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/FinancialReport"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <!-- 事件属性 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasEventId">
        <rdfs:label>事件ID</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/MarketEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasEventDate">
        <rdfs:label>事件日期</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/MarketEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasImpactLevel">
        <rdfs:label>影响级别</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/MarketEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- 投资者属性 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasInvestorId">
        <rdfs:label>投资者ID</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Investor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasInvestorName">
        <rdfs:label>投资者名称</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Investor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasInvestorType">
        <rdfs:label>投资者类型</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Investor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ==================== 新增属性：推理分析相关 ==================== -->

    <!-- 置信度 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasConfidence">
        <rdfs:label>置信度</rdfs:label>
        <rdfs:comment>分析结果或推理步骤的置信度 (0-1)</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <!-- 溯源ID -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasTraceId">
        <rdfs:label>溯源ID</rdfs:label>
        <rdfs:comment>用于全链路追溯的唯一标识</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- 时间戳 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasTimestamp">
        <rdfs:label>时间戳</rdfs:label>
        <rdfs:comment>记录创建时间</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>

    <!-- 推理规则名称 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasRuleApplied">
        <rdfs:label>应用规则</rdfs:label>
        <rdfs:comment>推理步骤中使用的规则名称（如：政策传导、产业链传导）</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/ReasoningStep"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- 证据描述 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasEvidence">
        <rdfs:label>证据</rdfs:label>
        <rdfs:comment>推理步骤的证据描述</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/ReasoningStep"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- 分析结果类型 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasResultType">
        <rdfs:label>结果类型</rdfs:label>
        <rdfs:comment>分析结果的类型（stock_analysis, event_impact, prediction等）</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/AnalysisResult"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- 分析内容 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasContent">
        <rdfs:label>内容</rdfs:label>
        <rdfs:comment>分析结果的文本内容</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/AnalysisResult"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- 预测模型类型 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasModelType">
        <rdfs:label>模型类型</rdfs:label>
        <rdfs:comment>预测使用的模型类型（lstm, gat, ensemble等）</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/PredictionRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- 预测方向 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasPredictionDirection">
        <rdfs:label>预测方向</rdfs:label>
        <rdfs:comment>预测的涨跌方向（up, down, neutral）</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/PredictionRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- 情感分数 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasSentimentScore">
        <rdfs:label>情感分数</rdfs:label>
        <rdfs:comment>情感分析的分数 (-1 到 1，负面到正面)</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/SentimentRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <!-- 情感标签 -->
    <owl:DatatypeProperty rdf:about="http://stock-ontology.org/hasSentimentLabel">
        <rdfs:label>情感标签</rdfs:label>
        <rdfs:comment>情感分类标签（positive, negative, neutral）</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/SentimentRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ==================== Object Properties ==================== -->

    <owl:ObjectProperty rdf:about="http://stock-ontology.org/belongsToIndustry">
        <rdfs:label>所属行业</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Company"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/Industry"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://stock-ontology.org/subIndustryOf">
        <rdfs:label>上级行业</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Industry"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/Industry"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://stock-ontology.org/competesWith">
        <rdfs:label>竞争关系</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Company"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/Company"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://stock-ontology.org/supplyTo">
        <rdfs:label>供应关系</rdfs:label>
        <rdfs:comment>A supplyTo B 表示 A 是 B 的供应商</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Company"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/Company"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://stock-ontology.org/impacts">
        <rdfs:label>影响</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/MarketEvent"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/FinancialEntity"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://stock-ontology.org/holds">
        <rdfs:label>持有</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Investor"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/Company"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://stock-ontology.org/hasFinancialReport">
        <rdfs:label>财务报告</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Company"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/FinancialReport"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://stock-ontology.org/correlatedWith">
        <rdfs:label>相关性</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/Company"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/Company"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://stock-ontology.org/causedBy">
        <rdfs:label>由...引起</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/MarketEvent"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/MarketEvent"/>
    </owl:ObjectProperty>

    <!-- ==================== 新增属性：推理传导相关 ==================== -->

    <!-- 传导至（传递性，用于事件影响传导推理） -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/transmitsTo">
        <rdfs:label>传导至</rdfs:label>
        <rdfs:comment>事件影响的传导关系，支持传递性推理：Event→Industry→Company</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>

    <!-- 依据（分析结果的证据来源） -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/evidencedBy">
        <rdfs:label>依据</rdfs:label>
        <rdfs:comment>分析结果的依据来源，关联到图谱中的具体实体</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/AnalysisResult"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/FinancialEntity"/>
    </owl:ObjectProperty>

    <!-- 因果链包含推理步骤 -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/hasReasoningStep">
        <rdfs:label>包含推理步骤</rdfs:label>
        <rdfs:comment>因果链包含的推理步骤</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/CausalChain"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/ReasoningStep"/>
    </owl:ObjectProperty>

    <!-- 推理步骤的源节点 -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/fromNode">
        <rdfs:label>源节点</rdfs:label>
        <rdfs:comment>推理步骤的起始实体</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/ReasoningStep"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/FinancialEntity"/>
    </owl:ObjectProperty>

    <!-- 推理步骤的目标节点 -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/toNode">
        <rdfs:label>目标节点</rdfs:label>
        <rdfs:comment>推理步骤的目标实体</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/ReasoningStep"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/FinancialEntity"/>
    </owl:ObjectProperty>

    <!-- 分析结果基于因果链 -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/basedOnChain">
        <rdfs:label>基于因果链</rdfs:label>
        <rdfs:comment>分析结果基于的因果传导链</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/AnalysisResult"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/CausalChain"/>
    </owl:ObjectProperty>

    <!-- 预测记录关联公司 -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/forCompany">
        <rdfs:label>预测目标公司</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/PredictionRecord"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/Company"/>
    </owl:ObjectProperty>

    <!-- 预测使用的技术指标 -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/usedFeature">
        <rdfs:label>使用特征</rdfs:label>
        <rdfs:comment>预测使用的技术指标或本体特征</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/PredictionRecord"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/TechnicalIndicator"/>
    </owl:ObjectProperty>

    <!-- 情感记录关联公司 -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/aboutCompany">
        <rdfs:label>关于公司</rdfs:label>
        <rdfs:domain rdf:resource="http://stock-ontology.org/SentimentRecord"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/Company"/>
    </owl:ObjectProperty>

    <!-- 情感记录来源事件 -->
    <owl:ObjectProperty rdf:about="http://stock-ontology.org/fromSource">
        <rdfs:label>来源</rdfs:label>
        <rdfs:comment>情感分析的来源（新闻、研报等）</rdfs:comment>
        <rdfs:domain rdf:resource="http://stock-ontology.org/SentimentRecord"/>
        <rdfs:range rdf:resource="http://stock-ontology.org/MarketEvent"/>
    </owl:ObjectProperty>

</rdf:RDF>
