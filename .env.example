# Application
APP_NAME=StockOntology
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-change-in-production

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# PostgreSQL/TimescaleDB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=stock_ontology

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Milvus (Vector Database)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=stock_embeddings

# ChromaDB (Alternative Vector Database)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=stock_docs

# OpenAI API (for LLM)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
OPENAI_API_BASE_URL=  # 留空使用默认OpenAI地址

# OpenAI-Compatible LLM Services (兼容OpenAI格式的LLM服务)
# 支持: Ollama, vLLM, text-generation-webui, DeepSeek, Qwen, etc.
LLM_PROVIDER=openai  # openai, ollama, vllm, local, deepseek, qwen
LLM_API_BASE_URL=http://localhost:8001/v1  # 自定义API地址
LLM_API_KEY=  # 自定义API密钥（如Ollama不需要）
LLM_MODEL=THUDM/chatglm3-6b  # 模型名称

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# vLLM Configuration
VLLM_HOST=http://localhost:8000
VLLM_MODEL=mistral-7b-instruct

# DeepSeek Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1

# Qwen Configuration
QWEN_API_KEY=your-qwen-api-key
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Xiaomi MiMo Configuration
XIAOMI_API_KEY=your-xiaomi-api-key
XIAOMI_API_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
XIAOMI_MODEL=mimo-v2.5-pro

# Local LLM (Alternative)
LOCAL_LLM_ENABLED=false
LOCAL_LLM_MODEL=THUDM/chatglm3-6b
LOCAL_LLM_URL=http://localhost:8001/v1

# Tushare (Data Source)
TUSHARE_TOKEN=your-tushare-token

# AKShare (Data Source)
AKSHARE_ENABLED=true

# Celery (Task Queue)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Model Paths
MODEL_DIR=models/checkpoints
PRETRAINED_DIR=models/pretrained
